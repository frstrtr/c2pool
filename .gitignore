# Vendored third-party libraries under external/ (e.g. external/dashbls).
# Source is tracked on the relevant branch; these are autotools/CMake/
# doxygen artifacts that get regenerated by the build and must not be
# committed. Patterns work whether or not the parent dir is tracked.
external/**/configure
external/**/configure~
external/**/config.log
external/**/config.status
external/**/config.status.old
external/**/libtool
external/**/aclocal.m4
external/**/Makefile
external/**/Makefile.in
external/**/stamp-h1
external/**/autom4te.cache/
external/**/build-aux/ar-lib
external/**/build-aux/compile
external/**/build-aux/config.guess
external/**/build-aux/config.sub
external/**/build-aux/depcomp
external/**/build-aux/install-sh
external/**/build-aux/ltmain.sh
external/**/build-aux/missing
external/**/build-aux/test-driver
external/**/.deps/
external/**/.libs/
external/**/CMakeCache.txt
external/**/CMakeFiles/
external/**/cmake_install.cmake
external/**/CTestTestfile.cmake
external/**/DartConfiguration.tcl
# libtoolize-generated m4 (the ax_* files alongside ARE tracked sources)
external/**/build-aux/m4/libtool.m4
external/**/build-aux/m4/ltoptions.m4
external/**/build-aux/m4/ltsugar.m4
external/**/build-aux/m4/ltversion.m4
external/**/build-aux/m4/lt~obsolete.m4
# automake .dirstamp markers
external/**/.dirstamp
# relic generated config (template is regenerated by autoreconf, per
# the dashbls vendoring commit notes — both .h and .h.in are artifacts)
external/**/relic_conf.h
external/**/relic_conf.h.in
external/**/relic_conf.h.old
# Doxygen output (e.g. external/dashbls/depends/mimalloc/docs/)
external/**/depends/**/docs/

# Release artifact staging area (built binaries, not source)
release-staging/
/.c2pool-bch-regtest/
